<Window x:Class="PhotoExplorer.App.Views.AlbumFolderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Width="520" Height="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 登録済みフォルダ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="登録済みフォルダ" FontWeight="Bold" Margin="0,0,0,4"/>
                <ListBox Grid.Row="1" x:Name="AlbumFolderList"
                         ItemsSource="{Binding AlbumFolders}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding}" MaxWidth="180"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- 中央ボタン -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                <Button Content="追加 ›" Click="Add_Click" Padding="8,4" Margin="0,0,0,8"
                        ToolTip="選択したフォルダをアルバムに追加"/>
                <Button Content="‹ 削除" Click="Remove_Click" Padding="8,4"
                        ToolTip="選択したフォルダをアルバムから削除"/>
            </StackPanel>

            <!-- 追加可能なフォルダ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="追加可能なフォルダ" FontWeight="Bold" Margin="0,0,0,4"/>
                <ListBox Grid.Row="1" x:Name="AvailableFolderList"
                         ItemsSource="{Binding AvailableFolders}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding}" MaxWidth="180"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!-- 完了ボタン -->
        <Button Grid.Row="1" Content="完了" HorizontalAlignment="Right"
                Click="Done_Click" Padding="16,4" Margin="0,8,0,0"/>
    </Grid>
</Window>
