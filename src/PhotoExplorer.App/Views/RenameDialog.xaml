<Window x:Class="PhotoExplorer.App.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="名前を変更" SizeToContent="Height" Width="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock Text="新しい表示名を入力してください" Margin="0,0,0,4"/>
        <TextBlock Text="（空欄でリセット）" Foreground="#888" FontSize="11" Margin="0,0,0,10"/>
        <TextBox x:Name="NameBox" Margin="0,0,0,14" KeyDown="NameBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" IsDefault="True" Width="80" Margin="0,0,8,0" Click="Ok_Click" Padding="0,4"/>
            <Button Content="キャンセル" IsCancel="True" Width="80" Padding="0,4"/>
        </StackPanel>
    </StackPanel>
</Window>
